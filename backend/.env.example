# Postgres connection (Supabase pooler / direct)
DATABASE_URL=postgres://postgres:password@db.YOUR-PROJECT.supabase.co:5432/postgres?sslmode=require

# Supabase JWT secret (Settings → API → JWT Secret).
# MVP проверяет HS256. Для прод-варианта переключить на JWKS:
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWKS_URL=

PORT=8080
